{
  "name": "rovas",
  "version": "0.1.0",
  "description": "Hungarian rovásírás (Old Hungarian runic script) transliteration library",
  "author": "Zoltán Rakottyai",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@vitest/coverage-v8": "^4.1.7",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "rovásírás",
    "rovas",
    "hungarian",
    "runic",
    "old-hungarian",
    "unicode",
    "transliteration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZRktty/rovas"
  },
  "homepage": "https://github.com/ZRktty/rovas#readme",
  "bugs": {
    "url": "https://github.com/ZRktty/rovas/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
